# BulutKlinik AI Service — ortam değişkenleri örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Uygulama ──────────────────────────────────────────────────────────── #
APP_NAME="BulutKlinik AI Service"
APP_VERSION="1.0.0"
DEBUG=false

# ── Veritabanı ────────────────────────────────────────────────────────── #
# C# backend ile aynı PostgreSQL instance kullanılabilir (farklı DB adı)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bulutklinik_ai

# ── OpenAI ────────────────────────────────────────────────────────────── #
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Depolama ──────────────────────────────────────────────────────────── #
UPLOAD_DIR=uploads/photos
ANNOTATED_DIR=uploads/annotated
MAX_UPLOAD_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────────────── #
# JSON dizisi olarak yazın
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# ── Güvenlik ──────────────────────────────────────────────────────────── #
# C# backend'deki appsettings.json'daki JWT Secret ile aynı olmalı
JWT_SECRET=super-secret-key-change-in-production
JWT_ALGORITHM=HS256
