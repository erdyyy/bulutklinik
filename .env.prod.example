# BulutKlinik — Production Environment Variables
# VPS'te /root/bulutklinik/.env olarak bir kez oluştur.
# GitHub Actions yalnızca IMAGE satırlarını günceller, diğerlerine dokunmaz.

# ── Docker image (GitHub Actions sed ile günceller) ───────────────────────
BULUTKLINIK_API_IMAGE=ghcr.io/GITHUB_KULLANICI/bulutklinik-api:latest
BULUTKLINIK_WEB_IMAGE=ghcr.io/GITHUB_KULLANICI/bulutklinik-web:latest
BULUTKLINIK_AI_IMAGE=ghcr.io/GITHUB_KULLANICI/bulutklinik-ai:latest

# ── PostgreSQL (VPS'teki postgres-db container'ı) ─────────────────────────
BULUTKLINIK_DB_CONN=Host=postgres-db;Port=5432;Database=bulutklinik;Username=postgres;Password=admin

# ── JWT ───────────────────────────────────────────────────────────────────
BULUTKLINIK_JWT_KEY=BURAYA_MIN_32_KARAKTER_GUCLU_SECRET_YAZ
BULUTKLINIK_JWT_ISSUER=http://195.35.1.138:8083

# ── Netgsm SMS (isteğe bağlı) ─────────────────────────────────────────────
NETGSM_ENABLED=false
NETGSM_USER_CODE=
NETGSM_PASSWORD=
NETGSM_HEADER=BulutKlinik

# ── SMTP Email (isteğe bağlı) ─────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── AI Servis API Anahtarları (en az birini doldur) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
